# ─── Database ─────────────────────────────────────────────────────────────────
# ✅ Hostnaam "db" = de Docker Compose service-naam. Niet aanpassen.
DATABASE_URL=postgresql://snackspot:snackspot@db:5432/snackspot

# ─── Redis ────────────────────────────────────────────────────────────────────
# ✅ Prima voor lokaal gebruik.
REDIS_URL=redis://redis:6379

# ─── MinIO (object storage) ───────────────────────────────────────────────────
# ✅ "minio" = Docker Compose service-naam. Niet aanpassen.
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
# ⚠️  Verander MINIO_ACCESS_KEY en MINIO_SECRET_KEY in productie.
MINIO_ACCESS_KEY=changeme
MINIO_SECRET_KEY=changeme
MINIO_BUCKET=snackspot
# ✅ localhost:9000 = de poort die Docker Compose naar buiten openzet.
#    Dit is de URL die de BROWSER gebruikt om foto's te uploaden/bekijken.
MINIO_PUBLIC_URL=http://localhost:9000

# ─── Auth ─────────────────────────────────────────────────────────────────────
# 🔑 VERVANG BEIDE SECRETS – dit zijn de cryptografische sleutels voor JWT-tokens.
JWT_ACCESS_SECRET=changeme
JWT_REFRESH_SECRET=changeme
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=7

# ─── App ──────────────────────────────────────────────────────────────────────
# ✅ Lokaal gebruik.
NODE_ENV=production
NEXT_PUBLIC_APP_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# ─── Upload limits ────────────────────────────────────────────────────────────
# ✅ 10 MB max per foto, max 5 foto's per review.
MAX_FILE_SIZE_BYTES=10485760
MAX_PHOTOS_PER_REVIEW=5

# Database
POSTGRES_PASSWORD=change-this-db-password
# Keep password in sync with POSTGRES_PASSWORD above.
DATABASE_URL=postgresql://snackspot:change-this-db-password@db:5432/snackspot

# Redis
REDIS_URL=redis://redis:6379

# MinIO object storage
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=change-this-minio-user
MINIO_SECRET_KEY=change-this-minio-password
MINIO_BUCKET=snackspot
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_REGION=us-east-1
# Optional: pin MinIO to an explicit release tag.
MINIO_IMAGE=minio/minio:latest

# Auth
JWT_ACCESS_SECRET=change-this-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-this-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=7

# App
NODE_ENV=production
TRUST_PROXY=true
NEXT_PUBLIC_APP_URL=http://localhost:8080
CORS_ORIGINS=http://localhost:8080

# Upload limits
MAX_FILE_SIZE_BYTES=10485760
MAX_PHOTOS_PER_REVIEW=5

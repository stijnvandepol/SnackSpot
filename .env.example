# Database
POSTGRES_PASSWORD=change-this-db-password
# Keep password in sync with POSTGRES_PASSWORD above.
DATABASE_URL=postgresql://snackspot:change-this-db-password@db:5432/snackspot

# Redis
REDIS_URL=redis://redis:6379

# MinIO object storage
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=change-this-minio-user
MINIO_SECRET_KEY=change-this-minio-password
MINIO_BUCKET=snackspot
MINIO_PUBLIC_URL=https://snackspot.online
MINIO_REGION=us-east-1
# CORS allowlist for direct browser uploads to MinIO (comma-separated origins).
# Set to * to avoid origin mismatch issues across LAN hostnames / tunnel domains.
MINIO_CORS_ORIGINS=*
# Optional: pin MinIO to an explicit release tag.
MINIO_IMAGE=minio/minio:RELEASE.2025-09-07T16-13-09Z-cpuv1

# Auth
JWT_ACCESS_SECRET=change-this-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-this-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=7
# Set to true when serving over HTTPS (required in production). Use false only for local HTTP/LAN dev.
AUTH_COOKIE_SECURE=true
ADMIN_BIND_ADDRESS=0.0.0.0
MINIO_API_BIND_ADDRESS=127.0.0.1
MINIO_CONSOLE_BIND_ADDRESS=127.0.0.1

# App
NODE_ENV=production
TRUST_PROXY=true
NEXT_PUBLIC_APP_URL=https://snackspot.online
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# API CORS allowlist (comma-separated origins).
CORS_ORIGINS=https://snackspot.online
# Host header whitelist (comma-separated). Leave empty to accept any host.
# Set to your public hostname in production, e.g. snackspot.online
ALLOWED_HOSTS=snackspot.online
# Log level: trace | debug | info | warn | error | fatal  (default: info in production)
LOG_LEVEL=info

# Email (Resend) — https://resend.com
RESEND_API_KEY=re_change-this-resend-api-key
RESEND_FROM_EMAIL=SnackSpot <noreply@snackspot.online>

# Upload limits
MAX_FILE_SIZE_BYTES=10485760
MAX_PHOTOS_PER_REVIEW=5

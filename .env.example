# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://snackspot:snackspot@db:5432/snackspot

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── MinIO (object storage) ──────────────────────────────────────────────────
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=snackspot
# Public URL used by the browser to upload directly and view images
MINIO_PUBLIC_URL=http://localhost:9000

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=change-me-access-secret-at-least-64-chars-long-random-string-here
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-64-chars-long-random-string-here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=7

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
NEXT_PUBLIC_APP_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# ─── Upload limits ───────────────────────────────────────────────────────────
MAX_FILE_SIZE_BYTES=10485760
MAX_PHOTOS_PER_REVIEW=5

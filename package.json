{
  "name": "snackspot",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.7.1",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "db:migrate": "pnpm --filter @snackspot/db migrate",
    "db:seed": "pnpm --filter @snackspot/db seed"
  }
}

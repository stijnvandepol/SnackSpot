{
  "name": "snackspot",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm run db:generate && pnpm --filter web build",
    "start": "pnpm --filter web start",
    "db:generate": "pnpm --filter @snackspot/db generate",
    "db:migrate": "pnpm --filter @snackspot/db migrate",
    "db:seed": "pnpm --filter @snackspot/db seed",
    "worker:dev": "pnpm --filter worker dev",
    "validate": "tsx scripts/validate-round-trip.ts"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "overrides": {
      "ioredis": "5.4.1"
    }
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "pg": "^8.13.0"
  }
}

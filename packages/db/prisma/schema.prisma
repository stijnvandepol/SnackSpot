generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  MODERATOR
  ADMIN
}

enum ReviewStatus {
  PUBLISHED
  HIDDEN
  DELETED
}

enum PhotoModerationStatus {
  PENDING
  PROCESSING
  APPROVED
  REJECTED
}

enum ReportStatus {
  OPEN
  RESOLVED
  DISMISSED
}

enum ReportTargetType {
  REVIEW
  PHOTO
  USER
}

enum ModerationActionType {
  HIDE_REVIEW
  UNHIDE_REVIEW
  DELETE_REVIEW
  DELETE_PHOTO
  BAN_USER
  UNBAN_USER
  DISMISS_REPORT
}

enum BadgeTier {
  BRONZE
  SILVER
  GOLD
}

enum BadgeCriteriaType {
  POSTS_COUNT
  UNIQUE_LOCATIONS_COUNT
  ACTIVE_DAYS_COUNT
  LIKES_RECEIVED_COUNT
  COMMENTS_RECEIVED_COUNT
  BEST_STREAK_DAYS
  POSTS_LAST_30_DAYS
}

enum NotificationType {
  REVIEW_LIKE
  REVIEW_COMMENT
  REVIEW_MENTION
  COMMENT_MENTION
  BADGE_EARNED

  @@map("notification_type")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  username     String    @unique
  bio          String?
  usernameChangedAt DateTime? @map("username_changed_at")
  passwordHash String    @map("password_hash")
  role         Role      @default(USER)
  avatarKey    String?   @map("avatar_key")
  bannedAt     DateTime? @map("banned_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  reviews           Review[]
  comments          Comment[]
  favorites         Favorite[]
  photos            Photo[]
  reviewLikes       ReviewLike[]
  userBadges        UserBadge[]
  reports           Report[]
  moderationActions ModerationAction[]
  refreshTokens     RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  notifications     Notification[]
  notificationPreferences NotificationPreferences?
  reviewMentionsReceived ReviewMention[] @relation("MentionedUser")
  reviewMentionsGiven    ReviewMention[] @relation("MentioningUser")
  pushSubscriptions PushSubscription[]
  actorNotifications Notification[] @relation("NotificationActor")
  blockedWords       BlockedWord[]
  reviewedFlags      FlaggedComment[] @relation("FlaggedCommentReviewer")

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  family    String    // shared across all rotations from one login session
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at") // set when rotated; non-null reuse = theft signal
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([family])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

/// location column is geography(Point,4326) – managed via raw SQL
model Place {
  id        String   @id @default(cuid())
  name      String
  address   String
  /// Stored as geography(Point,4326); use raw SQL for spatial ops
  location  Unsupported("geography(Point, 4326)")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  reviews   Review[]
  favorites Favorite[]

  @@map("places")
}

model Review {
  id       String       @id @default(cuid())
  userId   String       @map("user_id")
  placeId  String       @map("place_id")
  rating   Decimal      @default(0) @db.Decimal(2, 1)
  ratingTaste   Decimal @default(0) @db.Decimal(2, 1) @map("rating_taste")
  ratingValue   Decimal @default(0) @db.Decimal(2, 1) @map("rating_value")
  ratingPortion Decimal @default(0) @db.Decimal(2, 1) @map("rating_portion")
  ratingService Decimal? @db.Decimal(2, 1) @map("rating_service")
  ratingOverall Decimal @default(0) @db.Decimal(2, 1) @map("rating_overall")
  text     String
  dishName String?      @map("dish_name")
  status   ReviewStatus @default(PUBLISHED)
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  place        Place         @relation(fields: [placeId], references: [id], onDelete: Cascade)
  reviewLikes  ReviewLike[]
  comments     Comment[]
  reviewPhotos ReviewPhoto[]
  reports      Report[]
  mentions     ReviewMention[]
  notifications Notification[]
  tags          ReviewTag[]

  @@index([createdAt(sort: Desc)])
  @@index([placeId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc), id(sort: Desc)])
  @@index([userId, status, createdAt(sort: Desc)])
  @@index([placeId, status, createdAt(sort: Desc)])
  @@index([placeId, status, rating(sort: Desc), createdAt(sort: Desc)])
  @@index([userId, status, placeId])
  @@index([userId, status, id])
  @@map("reviews")
}

model ReviewTag {
  reviewId   String   @map("review_id")
  tag        String
  createdAt  DateTime @default(now()) @map("created_at")

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@id([reviewId, tag])
  @@index([tag, createdAt(sort: Desc)])
  @@map("review_tags")
}

model Badge {
  id            String           @id @default(cuid())
  slug          String           @unique
  name          String
  description   String
  iconKey       String           @map("icon_key")
  tier          BadgeTier
  criteriaType  BadgeCriteriaType @map("criteria_type")
  criteriaValue Int              @map("criteria_value")
  isActive      Boolean          @default(true) @map("is_active")
  createdAt     DateTime         @default(now()) @map("created_at")

  userBadges UserBadge[]

  @@map("badges")
}

model UserBadge {
  userId          String    @map("user_id")
  badgeId         String    @map("badge_id")
  progressCurrent Int       @default(0) @map("progress_current")
  progressTarget  Int       @default(0) @map("progress_target")
  earnedAt        DateTime? @map("earned_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@id([userId, badgeId])
  @@index([userId, earnedAt])
  @@index([userId, earnedAt(sort: Desc), createdAt])
  @@map("user_badges")
}

model ReviewLike {
  userId    String   @map("user_id")
  reviewId  String   @map("review_id")
  createdAt DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@id([userId, reviewId])
  @@index([reviewId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@map("review_likes")
}

model Comment {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  reviewId  String   @map("review_id")
  text      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  review         Review          @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  notifications  Notification[]
  flaggedComment FlaggedComment?

  @@index([reviewId, createdAt(sort: Desc), id(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@map("comments")
}

model BlockedWord {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  word      String   @unique
  createdBy String   @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  creator User @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@map("blocked_words")
}

model FlaggedComment {
  id          String    @id @default(dbgenerated("gen_random_uuid()"))
  commentId   String    @unique @map("comment_id")
  matchedWord String    @map("matched_word")
  status      String    @default("PENDING")
  reviewedBy  String?   @map("reviewed_by")
  reviewedAt  DateTime? @map("reviewed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  comment  Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  reviewer User?   @relation("FlaggedCommentReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@index([status, createdAt(sort: Desc)])
  @@map("flagged_comments")
}

model Photo {
  id               String                @id @default(cuid())
  storageKey       String                @unique @map("storage_key")
  uploaderId       String                @map("uploader_id")
  variants         Json                  @default("{}")
  metadata         Json                  @default("{}")
  moderationStatus PhotoModerationStatus @default(PENDING) @map("moderation_status")
  processedAt      DateTime?             @map("processed_at")
  createdAt        DateTime              @default(now()) @map("created_at")

  reviewPhotos ReviewPhoto[]
  uploader     User                  @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  reports      Report[]

  @@map("photos")
}

model ReviewPhoto {
  reviewId  String @map("review_id")
  photoId   String @map("photo_id")
  sortOrder Int    @default(0) @map("sort_order")

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  photo  Photo  @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@id([reviewId, photoId])
  @@index([reviewId, sortOrder])
  @@map("review_photos")
}

model Favorite {
  userId    String   @map("user_id")
  placeId   String   @map("place_id")
  createdAt DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@id([userId, placeId])
  @@map("favorites")
}

model Report {
  id         String           @id @default(cuid())
  reporterId String           @map("reporter_id")
  targetType ReportTargetType @map("target_type")
  reviewId   String?          @map("review_id")
  photoId    String?          @map("photo_id")
  reason     String
  status     ReportStatus     @default(OPEN)
  createdAt  DateTime         @default(now()) @map("created_at")

  reporter User    @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  review   Review? @relation(fields: [reviewId], references: [id], onDelete: SetNull)
  photo    Photo?  @relation(fields: [photoId], references: [id], onDelete: SetNull)

  @@index([status, createdAt(sort: Desc)])
  @@map("reports")
}

model ModerationAction {
  id          String               @id @default(cuid())
  moderatorId String               @map("moderator_id")
  actionType  ModerationActionType @map("action_type")
  targetType  String               @map("target_type")
  targetId    String               @map("target_id")
  note        String?
  createdAt   DateTime             @default(now()) @map("created_at")

  moderator User @relation(fields: [moderatorId], references: [id], onDelete: Cascade)

  @@map("moderation_actions")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  message   String
  link      String?
  isRead    Boolean          @default(false) @map("is_read")
  actorId   String?          @map("actor_id")
  reviewId  String?          @map("review_id")
  commentId String?          @map("comment_id")
  createdAt DateTime         @default(now()) @map("created_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  actor   User?    @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  review  Review?  @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  comment Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, isRead, createdAt(sort: Desc)])
  @@map("notifications")
}

model NotificationPreferences {
  userId         String   @id @map("user_id")
  emailOnLike    Boolean  @default(true) @map("email_on_like")
  emailOnComment Boolean  @default(true) @map("email_on_comment")
  emailOnMention Boolean  @default(true) @map("email_on_mention")
  emailOnBadge   Boolean  @default(true) @map("email_on_badge")
  pushOnLike     Boolean  @default(true) @map("push_on_like")
  pushOnComment  Boolean  @default(true) @map("push_on_comment")
  pushOnMention  Boolean  @default(true) @map("push_on_mention")
  pushOnBadge    Boolean  @default(true) @map("push_on_badge")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model ReviewMention {
  id                String   @id @default(cuid())
  reviewId          String   @map("review_id")
  mentionedUserId   String   @map("mentioned_user_id")
  mentionedByUserId String   @map("mentioned_by_user_id")
  createdAt         DateTime @default(now()) @map("created_at")

  review         Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  mentionedUser  User   @relation("MentionedUser", fields: [mentionedUserId], references: [id], onDelete: Cascade)
  mentionedByUser User  @relation("MentioningUser", fields: [mentionedByUserId], references: [id], onDelete: Cascade)

  @@unique([reviewId, mentionedUserId])
  @@index([mentionedUserId, createdAt(sort: Desc)])
  @@map("review_mentions")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  endpoint  String   @unique
  p256dhKey String   @map("p256dh_key")
  authKey   String   @map("auth_key")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}
